<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Tgm3Visualizer.Views.MasterModeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:master="using:Tgm3Visualizer.Controls.Master"
    xmlns:common="using:Tgm3Visualizer.Controls.Common"
    xmlns:vm="using:Tgm3Visualizer.ViewModels"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="95"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Player Info Card -->
        <common:PlayerInfoCard Grid.Row="0"
            Nickname="{x:Bind ViewModel.Nickname, Mode=OneWay}"
            DecorationPoints="{x:Bind ViewModel.DecorationPoints, Mode=OneWay}"
            IsLoggedIn="{x:Bind ViewModel.IsLoggedIn, Mode=OneWay}"
            WorldEasyHiScore="{x:Bind ViewModel.WorldEasyHiScore, Mode=OneWay}"
            ClassicEasyHiScore="{x:Bind ViewModel.ClassicEasyHiScore, Mode=OneWay}"
            WorldMasterGrade="{x:Bind ViewModel.WorldMasterGrade, Mode=OneWay}"
            ClassicMasterGrade="{x:Bind ViewModel.ClassicMasterGrade, Mode=OneWay}"
            WorldSakuraGrade="{x:Bind ViewModel.WorldSakuraGrade, Mode=OneWay}"
            ClassicSakuraGrade="{x:Bind ViewModel.ClassicSakuraGrade, Mode=OneWay}"
            WorldShiraseGrade="{x:Bind ViewModel.WorldShiraseGrade, Mode=OneWay}"
            ClassicShiraseGrade="{x:Bind ViewModel.ClassicShiraseGrade, Mode=OneWay}"/>

        <!-- Row 1: Menu Description Card -->
        <master:MenuDescription Grid.Row="1"
            ControlMode="{x:Bind ViewModel.ControlMode, Mode=OneWay}"
            GradeHistoryItems="{x:Bind ViewModel.GradeHistoryItems, Mode=OneWay}"
            AverageGrade="{x:Bind ViewModel.AverageGrade, Mode=OneWay}"
            DemotionProgress="{x:Bind ViewModel.DemotionProgress, Mode=OneWay}"/>

        <!-- Row 2: Level + Time Card -->
        <common:LevelTimeCard Grid.Row="2"
            Level="{x:Bind ViewModel.Level, Mode=OneWay}"
            FormattedTime="{x:Bind ViewModel.FormattedTime, Mode=OneWay}"/>

        <!-- Row 3: Grade / Cool / Regret Card -->
        <master:GradeCoolRegretCard Grid.Row="3"
            Grade="{x:Bind ViewModel.Grade, Mode=OneWay}"
            CoolDisplay="{x:Bind ViewModel.CoolDisplay, Mode=OneWay}"
            IsSectionCoolQualified="{x:Bind ViewModel.IsSectionCoolQualified, Mode=OneWay}"
            SectionRegretCount="{x:Bind ViewModel.SectionRegretCount, Mode=OneWay}"/>

        <!-- Row 4: Internal Grade Card -->
        <master:InternalGradeCard Grid.Row="4"
            InternalGradeText="{x:Bind ViewModel.InternalGradeText, Mode=OneWay}"
            IsInternalGradeQualified="{x:Bind ViewModel.IsInternalGradeQualified, Mode=OneWay}"
            IsMaxInternalGrade="{x:Bind ViewModel.IsMaxInternalGrade, Mode=OneWay}"
            StaffRollGradePointsDisplay="{x:Bind ViewModel.StaffRollGradePointsDisplay, Mode=OneWay}"
            AwardedGradePoints="{x:Bind ViewModel.AwardedGradePoints, Mode=OneWay}"
            AwardedGradePointsProgress="{x:Bind ViewModel.AwardedGradePointsProgress, Mode=OneWay}"
            DecayTime="{x:Bind ViewModel.DecayTime, Mode=OneWay}"
            DecayTimeProgress="{x:Bind ViewModel.DecayTimeProgress, Mode=OneWay}"/>

        <!-- Row 5: Section Times + Threshold + Playfield + Status Card -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Threshold + Section Times -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="79"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Threshold Card -->
                <master:ThresholdCard Grid.Row="0"
                    CoolDeadline="{x:Bind ViewModel.CoolDeadline, Mode=OneWay}"
                    RegretDeadline="{x:Bind ViewModel.RegretDeadline, Mode=OneWay}"/>

                <!-- Section Times Card -->
                <Border Grid.Row="1" Background="{ThemeResource PanelBackgroundBrush}" CornerRadius="6" Padding="4,2">
                    <master:SectionTimerControl Sections="{x:Bind ViewModel.Sections, Mode=OneWay}"/>
                </Border>
            </Grid>

            <!-- Right: Status + Playfield -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="79"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Status Card -->
                <master:StatusCard Grid.Row="0"
                    StatusCardTitle="{x:Bind ViewModel.StatusCardTitle, Mode=OneWay}"
                    StatusCardSubtitle="{x:Bind ViewModel.StatusCardSubtitle, Mode=OneWay}"
                    ShowStaffRollTime="{x:Bind ViewModel.ShowStaffRollTime, Mode=OneWay}"/>

                <!-- Playfield -->
                <common:PlayfieldCard Grid.Row="1"
                    ControlMode="{x:Bind ViewModel.ControlMode, Mode=OneWay}"
                    PlayfieldData="{x:Bind ViewModel.Playfield, Mode=OneWay}"
                    LockDelay="{x:Bind ViewModel.LockDelay, Mode=OneWay}"
                    MaxLockFrame="{x:Bind ViewModel.MaxLockFrame, Mode=OneWay}"
                    MoveResetText="{x:Bind ViewModel.MoveResetText, Mode=OneWay}"
                    Margin="6,0,0,0"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
