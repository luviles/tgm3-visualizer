<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Tgm3Visualizer.Views.SakuraModeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sakura="using:Tgm3Visualizer.Controls.Sakura"
    xmlns:common="using:Tgm3Visualizer.Controls.Common"
    xmlns:vm="using:Tgm3Visualizer.ViewModels"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Player Info Card -->
        <common:PlayerInfoCard Grid.Row="0"
            Nickname="{x:Bind ViewModel.Nickname, Mode=OneWay}"
            DecorationPoints="{x:Bind ViewModel.DecorationPoints, Mode=OneWay}"
            IsLoggedIn="{x:Bind ViewModel.IsLoggedIn, Mode=OneWay}"
            WorldEasyHiScore="{x:Bind ViewModel.WorldEasyHiScore, Mode=OneWay}"
            ClassicEasyHiScore="{x:Bind ViewModel.ClassicEasyHiScore, Mode=OneWay}"
            WorldMasterGrade="{x:Bind ViewModel.WorldMasterGrade, Mode=OneWay}"
            ClassicMasterGrade="{x:Bind ViewModel.ClassicMasterGrade, Mode=OneWay}"
            WorldSakuraGrade="{x:Bind ViewModel.WorldSakuraGrade, Mode=OneWay}"
            ClassicSakuraGrade="{x:Bind ViewModel.ClassicSakuraGrade, Mode=OneWay}"
            WorldShiraseGrade="{x:Bind ViewModel.WorldShiraseGrade, Mode=OneWay}"
            ClassicShiraseGrade="{x:Bind ViewModel.ClassicShiraseGrade, Mode=OneWay}"/>

        <!-- Row 1: Menu Description Card -->
        <sakura:MenuDescription Grid.Row="1" ControlMode="{x:Bind ViewModel.ControlMode, Mode=OneWay}"/>

        <!-- Row 2: Stage Card (Stage + Cleared + Jewels) -->
        <sakura:StageCard Grid.Row="2"
            Stage="{x:Bind ViewModel.SakuraStageLevelDisplay, Mode=OneWay}"
            ClearedStages="{x:Bind ViewModel.SakuraClearedStageLevel, Mode=OneWay}"
            JewelCount="{x:Bind ViewModel.RemainingJewelBlocks, Mode=OneWay}"
            ClearedForeground="{x:Bind ViewModel.ClearedForeground, Mode=OneWay}"/>

        <!-- Row 3: Stage Timer + StageTime + LimitTime + Playfield -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Stage Timer Card -->
            <Border Grid.Column="0" Background="{ThemeResource PanelBackgroundBrush}" CornerRadius="6" Padding="4,2">
                <sakura:StageTimerControl Sections="{x:Bind ViewModel.Sections, Mode=OneWay}"/>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Stage Time Card -->
                <sakura:StageTimeCard Grid.Row="0" Margin="6,0,0,6"
                    StageTime="{x:Bind ViewModel.SakuraStageLimitTime, Mode=OneWay}"/>

                <!-- Limit Time Card -->
                <sakura:LimitTimeCard Grid.Row="1" Margin="6,0,0,6"
                    LimitTime="{x:Bind ViewModel.FormattedTime, Mode=OneWay}"/>

                <!-- ExStage Status Card -->
                <sakura:ExStageStatusCard Grid.Row="2" Margin="6,0,0,6"
                    ExStageTier="{x:Bind ViewModel.ExStageTier, Mode=OneWay}"/>

                <!-- Right: Playfield -->
                <common:PlayfieldCard Grid.Row="3"
                    ControlMode="{x:Bind ViewModel.ControlMode, Mode=OneWay}"
                    PlayfieldData="{x:Bind ViewModel.Playfield, Mode=OneWay}"
                    LockDelay="{x:Bind ViewModel.LockDelay, Mode=OneWay}"
                    MaxLockFrame="{x:Bind ViewModel.MaxLockFrame, Mode=OneWay}"
                    MoveResetText="{x:Bind ViewModel.MoveResetText, Mode=OneWay}"
                    Margin="6,0,0,0"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
