<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Tgm3Visualizer.Views.ShiraseModeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shirase="using:Tgm3Visualizer.Controls.Shirase"
    xmlns:common="using:Tgm3Visualizer.Controls.Common"
    xmlns:vm="using:Tgm3Visualizer.ViewModels"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Player Info Card -->
        <common:PlayerInfoCard Grid.Row="0"
            Nickname="{x:Bind ViewModel.Nickname, Mode=OneWay}"
            DecorationPoints="{x:Bind ViewModel.DecorationPoints, Mode=OneWay}"
            IsLoggedIn="{x:Bind ViewModel.IsLoggedIn, Mode=OneWay}"
            WorldEasyHiScore="{x:Bind ViewModel.WorldEasyHiScore, Mode=OneWay}"
            ClassicEasyHiScore="{x:Bind ViewModel.ClassicEasyHiScore, Mode=OneWay}"
            WorldMasterGrade="{x:Bind ViewModel.WorldMasterGrade, Mode=OneWay}"
            ClassicMasterGrade="{x:Bind ViewModel.ClassicMasterGrade, Mode=OneWay}"
            WorldSakuraGrade="{x:Bind ViewModel.WorldSakuraGrade, Mode=OneWay}"
            ClassicSakuraGrade="{x:Bind ViewModel.ClassicSakuraGrade, Mode=OneWay}"
            WorldShiraseGrade="{x:Bind ViewModel.WorldShiraseGrade, Mode=OneWay}"
            ClassicShiraseGrade="{x:Bind ViewModel.ClassicShiraseGrade, Mode=OneWay}"/>

        <!-- Row 1: Menu Description Card -->
        <shirase:MenuDescription Grid.Row="1" ControlMode="{x:Bind ViewModel.ControlMode, Mode=OneWay}"/>

        <!-- Row 2: Level + Time Card -->
        <common:LevelTimeCard Grid.Row="2"
            Level="{x:Bind ViewModel.Level, Mode=OneWay}"
            FormattedTime="{x:Bind ViewModel.FormattedTime, Mode=OneWay}"/>

        <!-- Row 3: Grade / Regret Card -->
        <shirase:GradeRegretCard Grid.Row="3"
            Grade="{x:Bind ViewModel.Grade, Mode=OneWay}"
            SectionRegretCount="{x:Bind ViewModel.SectionRegretCount, Mode=OneWay}"/>

        <!-- Row 4: Section Times + Threshold + Playfield -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Status + Section Times -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="62"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Shirase Status Card -->
                <shirase:StatusCard Grid.Row="0" Margin="0,0,0,6"
                    StatusCardTitle="{x:Bind ViewModel.StatusCardTitle, Mode=OneWay}"
                    StatusCardSubtitle="{x:Bind ViewModel.StatusCardSubtitle, Mode=OneWay}"
                    ShowStaffRollTime="{x:Bind ViewModel.ShowStaffRollTime, Mode=OneWay}"
                    GarbageQuotaText="{x:Bind ViewModel.GarbageQuotaText, Mode=OneWay}"
                    GarbageQuotaValue="{x:Bind ViewModel.GarbageQuotaValue, Mode=OneWay}"
                    GarbageQuotaMax="{x:Bind ViewModel.GarbageQuotaMax, Mode=OneWay}"
                    ShowGarbageQuota="{x:Bind ViewModel.ShowGarbageQuota, Mode=OneWay}"/>
                
                <!-- Section Times Card -->
                <Border Grid.Row="1" Background="{ThemeResource PanelBackgroundBrush}" CornerRadius="6" Padding="4,2">
                    <shirase:SectionTimerControl Sections="{x:Bind ViewModel.Sections, Mode=OneWay}"/>
                </Border>
                
            </Grid>
        
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Threshold Card -->
                <shirase:ThresholdCard Grid.Row="0" Margin="6,0,0,0"
                    RegretDeadline="{x:Bind ViewModel.RegretDeadline, Mode=OneWay}"
                    Level500TimeLimit="{x:Bind ViewModel.Level500TimeLimit, Mode=OneWay}"
                    Level1000TimeLimit="{x:Bind ViewModel.Level1000TimeLimit, Mode=OneWay}"
                    IsLevel500Exceeded="{x:Bind ViewModel.IsLevel500Exceeded, Mode=OneWay}"
                    IsLevel1000Exceeded="{x:Bind ViewModel.IsLevel1000Exceeded, Mode=OneWay}"/>
                
                <!-- Right: Playfield -->
                <common:PlayfieldCard Grid.Row="2"
                    ControlMode="{x:Bind ViewModel.ControlMode, Mode=OneWay}"
                    PlayfieldData="{x:Bind ViewModel.Playfield, Mode=OneWay}"
                    LockDelay="{x:Bind ViewModel.LockDelay, Mode=OneWay}"
                    MaxLockFrame="{x:Bind ViewModel.MaxLockFrame, Mode=OneWay}"
                    MoveResetText="{x:Bind ViewModel.MoveResetText, Mode=OneWay}"
                    Margin="6,0,0,0"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
