<?xml version="1.0" ?>
<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="Tgm3Visualizer.Controls.Easy.HanabiScoreCard">
    <Border Background="{ThemeResource PanelBackgroundBrush}" CornerRadius="6" Padding="12">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="-10">
            <TextBlock Text="HANABI" FontSize="10" Foreground="#CCDDEE" HorizontalAlignment="Center"/>
            <TextBlock Text="{x:Bind HanabiScoreValue, Mode=OneWay}" Foreground="White" FontSize="80" FontWeight="Bold" HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
