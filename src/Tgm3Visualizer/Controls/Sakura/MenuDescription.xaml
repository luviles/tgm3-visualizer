<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Tgm3Visualizer.Controls.Sakura.MenuDescription"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{ThemeResource PanelBackgroundBrush}" CornerRadius="6" Height="130" Padding="10, 10">
        <StackPanel Spacing="6" VerticalAlignment="Center">
            <!-- Mode Name -->
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Outline layer -->
                <TextBlock Text="SAKURA" Foreground="#773644" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False"><TextBlock.RenderTransform><TranslateTransform X="-2" Y="0"/></TextBlock.RenderTransform></TextBlock>
                <TextBlock Text="SAKURA" Foreground="#773644" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False"><TextBlock.RenderTransform><TranslateTransform X="2" Y="0"/></TextBlock.RenderTransform></TextBlock>
                <TextBlock Text="SAKURA" Foreground="#773644" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False"><TextBlock.RenderTransform><TranslateTransform X="0" Y="-2"/></TextBlock.RenderTransform></TextBlock>
                <TextBlock Text="SAKURA" Foreground="#773644" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False"><TextBlock.RenderTransform><TranslateTransform X="0" Y="2"/></TextBlock.RenderTransform></TextBlock>
                <TextBlock Text="SAKURA" Foreground="#773644" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False"><TextBlock.RenderTransform><TranslateTransform X="-1" Y="-1"/></TextBlock.RenderTransform></TextBlock>
                <TextBlock Text="SAKURA" Foreground="#773644" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False"><TextBlock.RenderTransform><TranslateTransform X="-1" Y="1"/></TextBlock.RenderTransform></TextBlock>
                <TextBlock Text="SAKURA" Foreground="#773644" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False"><TextBlock.RenderTransform><TranslateTransform X="1" Y="-1"/></TextBlock.RenderTransform></TextBlock>
                <TextBlock Text="SAKURA" Foreground="#773644" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False"><TextBlock.RenderTransform><TranslateTransform X="1" Y="1"/></TextBlock.RenderTransform></TextBlock>
                <TextBlock Text="SAKURA" Foreground="#773644" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False"><TextBlock.RenderTransform><TranslateTransform X="-1" Y="0"/></TextBlock.RenderTransform></TextBlock>
                <TextBlock Text="SAKURA" Foreground="#773644" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False"><TextBlock.RenderTransform><TranslateTransform X="1" Y="0"/></TextBlock.RenderTransform></TextBlock>
                <TextBlock Text="SAKURA" Foreground="#773644" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False"><TextBlock.RenderTransform><TranslateTransform X="0" Y="-1"/></TextBlock.RenderTransform></TextBlock>
                <TextBlock Text="SAKURA" Foreground="#773644" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False"><TextBlock.RenderTransform><TranslateTransform X="0" Y="1"/></TextBlock.RenderTransform></TextBlock>
                <!-- Main text -->
                <TextBlock Text="SAKURA" Foreground="#FFC8FF" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
            </Grid>
            <!-- Control Mode -->
            <TextBlock Text="{x:Bind ControlMode, Mode=OneWay}" Foreground="#CCDDEE" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
