<?xml version="1.0" ?>
<UserControl x:Class="Tgm3Visualizer.Controls.Sakura.StageCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{ThemeResource PanelBackgroundBrush}" CornerRadius="6" Padding="10,10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="STAGE" FontSize="10" Foreground="#CCDDEE" HorizontalAlignment="Center"/>
                <TextBlock Text="{x:Bind Stage, Mode=OneWay}" Foreground="White" FontSize="40" FontWeight="Bold" HorizontalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="CLEARED" FontSize="10" Foreground="#CCDDEE" HorizontalAlignment="Center"/>
                <TextBlock Text="{x:Bind ClearedStages, Mode=OneWay}" Foreground="{x:Bind ClearedForeground, Mode=OneWay}" FontSize="40" FontWeight="Bold" HorizontalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="JEWELS" FontSize="10" Foreground="#CCDDEE" HorizontalAlignment="Center"/>
                <TextBlock Text="{x:Bind JewelCount, Mode=OneWay}" Foreground="White" FontSize="40" FontWeight="Bold" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
