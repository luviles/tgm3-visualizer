<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Tgm3Visualizer.Controls.Sakura.ExStageStatusCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{ThemeResource PanelBackgroundBrush}" CornerRadius="6" Padding="10,6">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
            <TextBlock Text="EXTRA STAGE" FontSize="9" Foreground="#CCDDEE" HorizontalAlignment="Center" Padding="0,0,0,6"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="19+ Stages Cleared" FontSize="11" Foreground="#CCDDEE"/>
                <TextBlock Grid.Column="1" x:Name="Ex3Text" Text="EX3" FontSize="11" FontWeight="Bold" Foreground="#556677"/>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="All Stages Cleared" FontSize="11" Foreground="#CCDDEE"/>
                <TextBlock Grid.Column="1" x:Name="Ex5Text" Text="EX5" FontSize="11" FontWeight="Bold" Foreground="#556677"/>
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="All Clear within 5:00" FontSize="11" Foreground="#CCDDEE"/>
                <TextBlock Grid.Column="1" x:Name="Ex7Text" Text="EX7" FontSize="11" FontWeight="Bold" Foreground="#556677"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
