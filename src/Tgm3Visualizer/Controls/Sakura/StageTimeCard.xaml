<?xml version="1.0" ?>
<UserControl x:Class="Tgm3Visualizer.Controls.Sakura.StageTimeCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{ThemeResource PanelBackgroundBrush}" CornerRadius="6" Padding="10,6">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="STAGE TIME" FontSize="9" Foreground="#CCDDEE" HorizontalAlignment="Center"/>
            <TextBlock Text="{x:Bind StageTime, Mode=OneWay}" Foreground="White" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
