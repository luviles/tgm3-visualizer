<?xml version="1.0" ?>
<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="Tgm3Visualizer.Controls.Shirase.ThresholdCard">
    <Border Background="{ThemeResource PanelBackgroundBrush}" CornerRadius="6" Padding="10,6" Margin="0,0,0,6">
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
            <StackPanel>
                <TextBlock Text="REGRET Deadline" FontSize="9" Foreground="#CCDDEE" HorizontalAlignment="Center"/>
                <TextBlock Text="{x:Bind RegretDeadline, Mode=OneWay}" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Level 500 Time Limit" FontSize="9" Foreground="#CCDDEE" HorizontalAlignment="Center"/>
                <TextBlock Text="{x:Bind Level500TimeLimit, Mode=OneWay}" Foreground="{x:Bind IsLevel500Exceeded, Mode=OneWay, Converter={StaticResource BoolToRedBrushConverter}}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Level 1000 Time Limit" FontSize="9" Foreground="#CCDDEE" HorizontalAlignment="Center"/>
                <TextBlock Text="{x:Bind Level1000TimeLimit, Mode=OneWay}" Foreground="{x:Bind IsLevel1000Exceeded, Mode=OneWay, Converter={StaticResource BoolToRedBrushConverter}}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
