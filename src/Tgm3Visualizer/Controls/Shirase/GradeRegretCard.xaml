<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Tgm3Visualizer.Controls.Shirase.GradeRegretCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{ThemeResource PanelBackgroundBrush}" CornerRadius="6" Padding="10,10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                <TextBlock Text="GRADE" FontSize="10" Foreground="#CCDDEE" HorizontalAlignment="Center"/>
                <TextBlock Text="{x:Bind Grade, Mode=OneWay}" Foreground="White" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                <TextBlock Text="REGRET" FontSize="10" Foreground="#CCDDEE" HorizontalAlignment="Center"/>
                <TextBlock Text="{x:Bind SectionRegretCount, Mode=OneWay}"
                           Foreground="White" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
