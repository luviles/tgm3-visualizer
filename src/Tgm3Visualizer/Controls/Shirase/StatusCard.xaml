<?xml version="1.0" ?>
<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:common="using:Tgm3Visualizer.Controls.Common"
             x:Class="Tgm3Visualizer.Controls.Shirase.StatusCard">

    <Border Background="{ThemeResource PanelBackgroundBrush}" CornerRadius="6" Padding="4">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
            <TextBlock Text="{x:Bind StatusCardTitle, Mode=OneWay}" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center"/>
            <TextBlock Text="{x:Bind StatusCardSubtitle, Mode=OneWay}" Foreground="#CCDDEE" FontSize="14" HorizontalAlignment="Center" Visibility="{x:Bind ShowStaffRollTime, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <!-- Garbage Quota Section (Rising Garbage mode, levels 500-999) -->
            <StackPanel Visibility="{x:Bind ShowGarbageQuota, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" HorizontalAlignment="Center" Spacing="2">
                <TextBlock Text="{x:Bind GarbageQuotaText, Mode=OneWay}" Foreground="#CCDDEE" FontSize="12" HorizontalAlignment="Center"/>
                <common:AtomicProgressBar Height="6" HorizontalAlignment="Center"
                    Width="134"
                    Value="{x:Bind GarbageQuotaValue, Mode=OneWay}"
                    Maximum="{x:Bind GarbageQuotaMax, Mode=OneWay}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
