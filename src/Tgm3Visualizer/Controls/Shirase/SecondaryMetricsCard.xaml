<?xml version="1.0" ?>
<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:common="using:Tgm3Visualizer.Controls.Common" x:Class="Tgm3Visualizer.Controls.Shirase.SecondaryMetricsCard">

    <Border Background="{ThemeResource PanelBackgroundBrush}" CornerRadius="6" Padding="10,8">

        <Grid>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,6">
                <TextBlock Text="Big Block" FontSize="9" Foreground="#CCDDEE"/>
                <TextBlock Text="OFF" Foreground="White" FontSize="14" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,6" HorizontalAlignment="Right">
                <TextBlock Text="Speed" FontSize="9" Foreground="#CCDDEE" HorizontalAlignment="Right"/>
                <TextBlock Text="20G" Foreground="White" FontSize="14" HorizontalAlignment="Right" FontWeight="Bold"/>
            </StackPanel>

            <StackPanel Grid.Column="0" Grid.Row="1">
                <TextBlock Text="Next Section Goal" FontSize="9" Foreground="#CCDDEE"/>
                <TextBlock Text="0:42" Foreground="White" FontSize="14" FontWeight="Bold"/>
                <common:AtomicProgressBar Value="0.5" Maximum="1" Height="4" Width="200" HorizontalAlignment="Left" Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Grid.Row="1" HorizontalAlignment="Right">
                <TextBlock Text="Current Section" FontSize="9" Foreground="#CCDDEE" HorizontalAlignment="Right"/>
                <TextBlock Text="0:35" Foreground="White" FontSize="14" HorizontalAlignment="Right" FontWeight="Bold"/>
                <common:AtomicProgressBar Value="0.7" Maximum="1" Height="4" Width="200" HorizontalAlignment="Right" Margin="0,4,0,0"/>
            </StackPanel>

        </Grid>

    </Border>

</UserControl>
