<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Tgm3Visualizer.Controls.Master.MenuDescription"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Tgm3Visualizer.ViewModels">

    <Border Background="{ThemeResource PanelBackgroundBrush}" CornerRadius="6" Height="130">
        <Grid VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="23"/>
                <RowDefinition Height="27"/>
                <RowDefinition Height="18"/>
            </Grid.RowDefinitions>

            <!-- Mode Name -->
            <Grid Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Outline layer -->
                <TextBlock Text="MASTER" Foreground="#5A454F" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock.RenderTransform>
                        <TranslateTransform X="-2" Y="0"/>
                    </TextBlock.RenderTransform></TextBlock>
                <TextBlock Text="MASTER" Foreground="#5A454F" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock.RenderTransform>
                        <TranslateTransform X="2" Y="0"/>
                    </TextBlock.RenderTransform></TextBlock>
                <TextBlock Text="MASTER" Foreground="#5A454F" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock.RenderTransform>
                        <TranslateTransform X="0" Y="-2"/>
                    </TextBlock.RenderTransform></TextBlock>
                <TextBlock Text="MASTER" Foreground="#5A454F" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock.RenderTransform>
                        <TranslateTransform X="0" Y="2"/>
                    </TextBlock.RenderTransform></TextBlock>
                <TextBlock Text="MASTER" Foreground="#5A454F" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock.RenderTransform>
                        <TranslateTransform X="-1" Y="-1"/>
                    </TextBlock.RenderTransform></TextBlock>
                <TextBlock Text="MASTER" Foreground="#5A454F" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock.RenderTransform>
                        <TranslateTransform X="-1" Y="1"/>
                    </TextBlock.RenderTransform></TextBlock>
                <TextBlock Text="MASTER" Foreground="#5A454F" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock.RenderTransform>
                        <TranslateTransform X="1" Y="-1"/>
                    </TextBlock.RenderTransform></TextBlock>
                <TextBlock Text="MASTER" Foreground="#5A454F" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock.RenderTransform>
                        <TranslateTransform X="1" Y="1"/>
                    </TextBlock.RenderTransform></TextBlock>
                <TextBlock Text="MASTER" Foreground="#5A454F" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock.RenderTransform>
                        <TranslateTransform X="-1" Y="0"/>
                    </TextBlock.RenderTransform></TextBlock>
                <TextBlock Text="MASTER" Foreground="#5A454F" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock.RenderTransform>
                        <TranslateTransform X="1" Y="0"/>
                    </TextBlock.RenderTransform></TextBlock>
                <TextBlock Text="MASTER" Foreground="#5A454F" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock.RenderTransform>
                        <TranslateTransform X="0" Y="-1"/>
                    </TextBlock.RenderTransform></TextBlock>
                <TextBlock Text="MASTER" Foreground="#5A454F" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock.RenderTransform>
                        <TranslateTransform X="0" Y="1"/>
                    </TextBlock.RenderTransform></TextBlock>
                <!-- Main text -->
                <TextBlock Text="MASTER" Foreground="#B4DCFF" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
            </Grid>

            <!-- Control Mode -->
            <TextBlock Grid.Row="1" Text="{x:Bind ControlMode, Mode=OneWay}" Foreground="#CCDDEE" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="0, 4, 0, 0"/>

            <!-- HISTORY label -->
            <Grid Grid.Row="2" HorizontalAlignment="Center" Padding="0, 8, 0, 0">
                <!-- History values -->
                <ItemsControl Grid.Column="1" ItemsSource="{x:Bind GradeHistoryItems, Mode=OneWay}" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:GradeHistoryItem">
                            <TextBlock Text="{x:Bind GradeName, Mode=OneWay}"
                                       FontSize="14" FontWeight="Bold" 
                                       Foreground="{x:Bind IsHighlighted, Mode=OneWay, Converter={StaticResource HighlightToColorConverter}}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <!-- Adjusted Average Grade / Demotion Points -->
            <Grid Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="0, 4, 0, 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="30"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Adjusted Average Grade: " HorizontalAlignment="Right" FontSize="10" Foreground="#CCDDEE" Margin="-23, 0, 0, 0" Padding="0, 0, 4, 0"/>
                <TextBlock Grid.Column="1" Text="{x:Bind AverageGrade, Mode=OneWay}" HorizontalAlignment="Left" FontSize="10" FontWeight="Bold" Foreground="White" />
                <TextBlock Grid.Column="3" Text="Demotion Points: " HorizontalAlignment="Right" FontSize="10" Foreground="#CCDDEE" Padding="0, 0, 4, 0"/>
                <TextBlock Grid.Column="4" Text="{x:Bind DemotionProgress, Mode=OneWay}" HorizontalAlignment="Left" FontSize="10" FontWeight="Bold" Foreground="White"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
