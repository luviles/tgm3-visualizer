<?xml version="1.0" ?>
<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="Tgm3Visualizer.Controls.Master.ThresholdCard">
    <Border Background="{ThemeResource PanelBackgroundBrush}" CornerRadius="6" Padding="10,6" Margin="0,0,0,6">        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="28">            
            <StackPanel>                
                <TextBlock Text="COOL Deadline" FontSize="9" Foreground="#CCDDEE" HorizontalAlignment="Center"/>                
                <TextBlock Text="{x:Bind CoolDeadline, Mode=OneWay}" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>                
            </StackPanel>
            
            <StackPanel>                
                <TextBlock Text="REGRET Deadline" FontSize="9" Foreground="#CCDDEE" HorizontalAlignment="Center"/>                
                <TextBlock Text="{x:Bind RegretDeadline, Mode=OneWay}" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>                
            </StackPanel>            
        </StackPanel>        
    </Border>    
</UserControl>
