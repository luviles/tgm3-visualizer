<?xml version="1.0" ?>
<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:common="using:Tgm3Visualizer.Controls.Common" x:Class="Tgm3Visualizer.Controls.Master.InternalGradeCard">
    <Border Background="{ThemeResource PanelBackgroundBrush}" CornerRadius="6" Padding="10,8">        
        <Grid>            
            <Grid.ColumnDefinitions>                
                <ColumnDefinition Width="*"/>                
                <ColumnDefinition Width="*"/>                
            </Grid.ColumnDefinitions>      
            
            <Grid.RowDefinitions>                
                <RowDefinition Height="Auto"/>                
                <RowDefinition Height="Auto"/>                
                <RowDefinition Height="Auto"/>                
            </Grid.RowDefinitions>

            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,6" VerticalAlignment="Center">                
                <TextBlock Text="Internal Grade" FontSize="9" Foreground="#CCDDEE"/>
                <TextBlock x:Name="InternalGradeTextBlock" Text="{x:Bind InternalGradeText, Mode=OneWay}" FontSize="14" FontWeight="Bold" Foreground="White"/>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,6" HorizontalAlignment="Right" VerticalAlignment="Center">                
                <TextBlock Text="Staff Roll Grade" FontSize="9" Foreground="#CCDDEE" HorizontalAlignment="Right"/>                
                <TextBlock Text="{x:Bind StaffRollGradePointsDisplay, Mode=OneWay}" Foreground="White" FontSize="14" HorizontalAlignment="Right" FontWeight="Bold"/>                
            </StackPanel>

            <StackPanel Grid.Column="0" Grid.Row="1" VerticalAlignment="Center">                
                <TextBlock Text="Grade Points" FontSize="9" Foreground="#CCDDEE"/>                
                <TextBlock Text="{x:Bind AwardedGradePoints, Mode=OneWay}" Foreground="White" FontSize="14" FontWeight="Bold"/>                
                <common:AtomicProgressBar Value="{x:Bind AwardedGradePointsProgress, Mode=OneWay}" Maximum="1" Height="4" Width="150" HorizontalAlignment="Left" Margin="0,4,0,0"/>                
            </StackPanel>

            <StackPanel Grid.Column="1" Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Center">                
                <TextBlock Text="Decay Time Remaining" FontSize="9" Foreground="#CCDDEE" HorizontalAlignment="Right"/>                
                <TextBlock Foreground="White" FontSize="14" HorizontalAlignment="Right" FontWeight="Bold">
                    <Run Text="{x:Bind DecayTime, Mode=OneWay}"/>
                </TextBlock>
                
                <common:AtomicReverseProgressBar Value="{x:Bind DecayTimeProgress, Mode=OneWay}" Maximum="1" Height="4" Width="150" HorizontalAlignment="Right" Margin="0,4,0,0"/>                
            </StackPanel>            
        </Grid>        
    </Border>    
</UserControl>
