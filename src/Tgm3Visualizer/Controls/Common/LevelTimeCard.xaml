<?xml version="1.0" ?>
<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" x:Class="Tgm3Visualizer.Controls.Common.LevelTimeCard">

    <Border Background="{ThemeResource PanelBackgroundBrush}" CornerRadius="6" Padding="10, 10">

        <Grid>

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="*"/>

                <ColumnDefinition Width="*"/>

            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">

                <TextBlock Text="LEVEL" FontSize="10" Foreground="#CCDDEE" HorizontalAlignment="Center"/>

                <TextBlock Text="{x:Bind Level, Mode=OneWay}" Foreground="White" FontSize="40" FontWeight="Bold" HorizontalAlignment="Center"/>

            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">

                <TextBlock Text="TIME" FontSize="10" Foreground="#CCDDEE" HorizontalAlignment="Center"/>

                <TextBlock Text="{x:Bind FormattedTime, Mode=OneWay}" Foreground="White" FontSize="40" FontWeight="Bold" HorizontalAlignment="Center"/>

            </StackPanel>

        </Grid>

    </Border>

</UserControl>
