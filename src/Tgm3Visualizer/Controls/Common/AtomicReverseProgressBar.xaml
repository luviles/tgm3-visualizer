<?xml version="1.0" ?>
<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Tgm3Visualizer.Controls.Common.AtomicReverseProgressBar">

    <Grid Height="{x:Bind Height, Mode=OneWay}">
        <!-- Track -->
        <Rectangle Fill="#3A3A3A" RadiusX="2" RadiusY="2"/>
        <!-- Indicator (right-aligned, shrinks from left) -->
        <Rectangle Fill="#FFFFFF" RadiusX="2" RadiusY="2"
                   HorizontalAlignment="Right"
                   Width="{x:Bind ProgressWidth, Mode=OneWay}"/>
    </Grid>

</UserControl>
