<?xml version="1.0" ?>
<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:common="using:Tgm3Visualizer.Controls.Common" x:Class="Tgm3Visualizer.Controls.Common.PlayfieldCard">
    <Border Background="{ThemeResource PanelBackgroundBrush}" CornerRadius="6" Padding="6,8">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Playfield" FontSize="9" Foreground="#CCDDEE" HorizontalAlignment="Center"/>

            <Border BorderBrush="#CCDDEE" BorderThickness="1" Margin="0,4,0,0" HorizontalAlignment="Center">
                <Image Source="{x:Bind PlayfieldBitmap, Mode=OneWay}" Stretch="Uniform" MaxWidth="250"/>
            </Border>

            <!-- Lock Delay Progress Bar -->
            <common:AtomicProgressBar Value="{x:Bind LockDelay, Mode=OneWay}"
                         Maximum="{x:Bind MaxLockFrame, Mode=OneWay}"
                         Height="4" Width="192"
                         HorizontalAlignment="Center"
                         Margin="0,6,0,2"/>

            <!-- Lock Delay / Move Reset Text -->
            <StackPanel Spacing="2" HorizontalAlignment="Center">
                <TextBlock Text="{x:Bind LockDelayDisplayText, Mode=OneWay}" FontSize="11" Foreground="#CCDDEE"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="{x:Bind MoveResetText, Mode=OneWay}" FontSize="11" Foreground="#CCDDEE"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
