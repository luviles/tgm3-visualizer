<?xml version="1.0" ?>
<UserControl xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:vm="using:Tgm3Visualizer.ViewModels" x:Class="Tgm3Visualizer.Controls.SectionTimerControl">
    
    <ListView ItemsSource="{x:Bind Sections, Mode=OneWay}" SelectionMode="None" Padding="0" Margin="0">
        
        <ListView.ItemTemplate>
            
            <DataTemplate x:DataType="vm:SectionInfo">
                
                <Grid Padding="-10,1">
                    
                    <Grid.ColumnDefinitions>
                        
                        <ColumnDefinition Width="70"/>
                        
                        <ColumnDefinition Width="60"/>
                        
                        <ColumnDefinition Width="10"/>
                        
                        <ColumnDefinition Width="*"/>
                        
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="{x:Bind Range, Mode=OneWay}" Foreground="#CCDDEE"/>
                    
                    <!-- Duration -->
                    
                    <TextBlock Grid.Column="1" Text="{x:Bind Time, Mode=OneWay}" Foreground="{x:Bind Status, Mode=OneWay, Converter={StaticResource SectionStatusConverter}}" FontWeight="Bold"/>
                    
                    <!-- Separator -->
                    
                    <TextBlock Grid.Column="2" Text="|" Opacity="0.5" Visibility="{x:Bind CumulativeTime, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}"/>
                    
                    <!-- Cumulative Time -->
                    
                    <TextBlock Grid.Column="3" Text="{x:Bind CumulativeTime, Mode=OneWay}" Foreground="#FFFFFF" Opacity="0.7"/>
                    
                </Grid>
                
            </DataTemplate>
            
        </ListView.ItemTemplate>
        
    </ListView>
    
</UserControl>
